<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pack Simulator — <%= it.site.title %></title>
    <meta name="description" content="Simulate opening a pack of cards from supported sets.">
    <base href="<%= it.site.baseUrl %>/">

    <!-- Open Graph -->
    <meta property="og:title" content="Pack Simulator — <%= it.site.title %>">
    <meta property="og:description" content="Simulate opening a pack of cards from supported sets.">
    <meta property="og:image" content="<%= it.site.baseUrl %>/resources/logo.png">
    <meta property="og:url" content="<%= it.site.baseUrl %>/simulator">
    <meta property="og:type" content="website">

    <link rel="icon" href="resources/favicon.ico">
    <link rel="stylesheet" href="styles/base.css">
    <link rel="stylesheet" href="styles/components.css">
    <link rel="stylesheet" href="styles/set.css">

    <script type="module" src="scripts/main.js"></script>
    <script type="module" src="scripts/simulator.js"></script>
</head>
<body>
    <%~ include('header') %>

    <main class="set-page">
        <header class="set-header">
            <div class="set-header-meta">
                <h1 class="set-header-name">Pack Simulator</h1>
                <p class="set-header-details">Open a virtual pack</p>
            </div>
            <div class="set-header-controls">
                <label class="set-control-label">
                    Select Set
                    <select class="set-control-select" id="set-select">
                        <option value="">-- Choose a set --</option>
                        <% for (const set of it.sets) { %>
                        <option value="<%= set.code %>"><%= set.name %> (<%= set.code %>)</option>
                        <% } %>
                    </select>
                </label>
                <button id="open-pack-btn" class="set-control-select" style="cursor: pointer; background: var(--color-accent); color: #000; border: none; padding: 0.5rem 1rem; border-radius: 4px; font-weight: bold;">Open Pack</button>
            </div>
        </header>

        <section class="card-grid-section">
            <div class="card-grid" id="pack-results">
                <!-- Pack results will appear here -->
            </div>
        </section>

        <div class="card-zoom-overlay" id="card-zoom-overlay" aria-hidden="true">
            <img class="card-zoom-image" id="card-zoom-image" alt="" />
        </div>
    </main>

    <%~ include('footer') %>
</body>
</html>
