<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= it.site.title %></title>
    <meta name="description" content="<%= it.site.description %>">
    <base href="<%= it.site.baseUrl %>/">

    <!-- Open Graph -->
    <meta property="og:title" content="<%= it.site.title %>">
    <meta property="og:description" content="<%= it.site.description %>">
    <meta property="og:image" content="<%= it.site.baseUrl %>/resources/logo.png">
    <meta property="og:url" content="<%= it.site.baseUrl %>">
    <meta property="og:type" content="website">

    <link rel="icon" href="resources/favicon.ico">
    <link rel="stylesheet" href="styles/base.css">
    <link rel="stylesheet" href="styles/components.css">
    <link rel="stylesheet" href="styles/sets.css">

    <script type="module" src="scripts/main.js"></script>
</head>
<body>
    <%~ include('header') %>

    <main class="sets">
        <section>
            <h2 class="section-title">All Sets</h2>
            <div class="set-grid">
                <% for (const set of it.sets) { %>
                <a href="sets/<%= set.setCode %>" class="set-full">
                    <div>
                        <div class="set-symbol-wrap">
                            <%~ set.symbol %>
                        </div>
                    </div>
                    <div>
                        <h3><%= set.title %></h3>
                        <div class="set-description">
                            <% if (set.description) { %>
                            <%= set.description %>
                            <% } else { %>
                            <i>No description</i>
                            <% } %>
                        </div>
                    </div>
                </a>
                <% } %>
            </div>
        </section>
    </main>

    <%~ include('footer') %>
</body>
</html>
